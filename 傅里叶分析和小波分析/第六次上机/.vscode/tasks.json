{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "运行当前 MATLAB 文件",
            "type": "shell",
            "command": "matlab",
            "args": [
                "-batch",
                "run('${file}'); exit"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": false
            },
            "problemMatcher": [],
            "windows": {
                "options": {
                    "shell": {
                        "executable": "powershell.exe",
                        "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-Command"]
                    }
                }
            }
        },
        {
            "label": "运行当前 MATLAB 文件 (Octave)",
            "type": "shell",
            "command": "octave",
            "args": [
                "${file}"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "运行当前 MATLAB 文件 (交互模式)",
            "type": "shell",
            "command": "matlab",
            "args": [
                "-r",
                "run('${file}'); pause; exit"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        }
    ]
}


